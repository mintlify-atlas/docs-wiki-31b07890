    "POST /journalentries (JournalEntriesApiResource)",
    "GET /glaccounts (GLAccountsApiResource)",
    "POST /batches (BatchApiResource)",
    "GET /jobs and POST /jobs/{jobId} (SchedulerJobApiResource)",
    "GET /scheduler (SchedulerApiResource)",
    "POST /externalevents (ExternalEventConfigurationApiResource)",
    "POST /externalassetowners (ExternalAssetOwnersApiResource)",
    "POST /cob/loan and /cob/workingcapitalloan (LoanCOBCatchUpApiResource, WorkingCapitalLoanCOBCatchUpApiResource)",
    "POST /interoperation (InteropApiResource)",
    "POST /makercheckers (MakercheckersApiResource)",
    "POST /twofactor (TwoFactorApiResource)",
    "fineract-client (OkHttp/Retrofit SDK)",
